# ──────────────────────────────────────────────────────────────
#  Configuración del stack stepca-docker
#  Copiá este archivo a .env y ajustá los valores.
# ──────────────────────────────────────────────────────────────

# Imagen de step-ca. RECOMENDADO fijar una versión (no usar 'latest' en prod).
# Ver tags en https://hub.docker.com/r/smallstep/step-ca/tags
STEPCA_IMAGE=smallstep/step-ca:0.28.3

# ── Identidad de la Root CA ──
STEPCA_INIT_NAME=Maximiliano Iriart
STEPCA_INIT_DNS_NAMES=stepca-root, localhost, 127.0.0.1, rootca.local
STEPCA_INIT_PROVISIONER=admin@example.com

# ── CA intermedia ──
INTERMEDIATE_DNS=stepca-intermediate
INTERMEDIATE_KEY_SIZE=4096
INTERMEDIATE_PROFILE=intermediate-ca

# ── Puertos publicados en el host ──
ROOT_PORT=9000
INTERMEDIATE_PORT=9001
RA_PORT=9100

# ── Debug (1 = verboso) ──
STEPDEBUG=0
