{
  "title": "step-ca — PKI Overview",
  "uid": "stepca-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "CAs up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(up{job=~\"stepca.*\"})" }]
    },
    {
      "type": "timeseries",
      "title": "Certificados emitidos (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(step_ca_provisioner_sign_total[5m])" }]
    },
    {
      "type": "timeseries",
      "title": "Latencia de firma (p95)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(step_ca_request_duration_seconds_bucket[5m]))" }]
    },
    {
      "type": "timeseries",
      "title": "Errores HTTP 5xx",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(step_ca_requests_total{code=~\"5..\"}[5m])" }]
    }
  ]
}
